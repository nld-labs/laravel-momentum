{
    "name": "nld-labs/laravel-momentum",
    "description": "A Laravel library to streamline Inertia.js application development.",
    "type": "library",
    "license": "MIT",
    "version": "0.4.1",
    "keywords": [
        "laravel",
        "inertia"
    ],
    "autoload": {
        "psr-4": {
            "NLD\\Momentum\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NLD\\Momentum\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Vitauts Stočka",
            "email": "vs@vits.lv"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.2",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "inertiajs/inertia-laravel": "^3.0"
    },
    "require-dev": {
        "pestphp/pest": "^4.3",
        "laravel/pint": "^1.27",
        "orchestra/testbench": "^11.0"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "NLD\\Momentum\\MomentumServiceProvider"
            ]
        }
    }
}
